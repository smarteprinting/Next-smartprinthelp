# Cache strategy for Netlify
# HTML should revalidate so users get latest deploy quickly
/*
  Cache-Control: public, max-age=0, must-revalidate

# Fingerprinted Vite assets can be cached for 1 year (immutable hash)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Static images in public root/categories are not fingerprinted, keep moderate TTL
/logo-bgremove.png
  Cache-Control: public, max-age=604800
/logo-bgremove-224.png
  Cache-Control: public, max-age=604800
/logo.png
  Cache-Control: public, max-age=604800
/favicon.png
  Cache-Control: public, max-age=604800
/categories/*
  Cache-Control: public, max-age=2592000

# Manifest and robots for SEO/PWA
/manifest.json
  Cache-Control: public, max-age=86400
/robots.txt
  Cache-Control: public, max-age=86400
